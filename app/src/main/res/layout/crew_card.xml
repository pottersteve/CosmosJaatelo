<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_margin="4dp"
    android:background="#2D1050"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/card_image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="#3D1A60"
            tools:src="@tools:sample/avatars" />

        <TextView
            android:id="@+id/card_name_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Name\nRole"
            android:textColor="#FFB3DE"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView android:id="@+id/card_loc" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="#1A0A2E" android:text=" Loc: Unknown" android:textColor="#C084B8" android:textSize="10sp" android:padding="2dp"/>
    <TextView android:id="@+id/card_exp" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:background="#1A0A2E" android:text=" Exp: 0" android:textColor="#C084B8" android:textSize="10sp" android:padding="2dp"/>
    <TextView android:id="@+id/card_energy" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:background="#1A0A2E" android:text=" Energy: 0%" android:textColor="#C084B8" android:textSize="10sp" android:padding="2dp"/>

    <TextView android:id="@+id/card_cost" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Cost: 0" android:textColor="#00FF00" android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
</LinearLayout>