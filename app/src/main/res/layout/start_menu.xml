<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0A2E"
    android:gravity="center_horizontal">

    <!-- top stat buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/starterMissionsBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mission Stat"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6A0050"
            android:textColor="#FFB3DE"/>

        <Button
            android:id="@+id/starterCrewBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Crew Stat"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#6A0050"
            android:textColor="#FFB3DE"/>

        <Button
            android:id="@+id/starterRecordBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="blank for now"
            android:backgroundTint="#6A0050"
            android:textColor="#FFB3DE"/>

    </LinearLayout>

    <!-- game title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COSMOS JÄÄTELÖ"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFB3DE"
        android:layout_marginTop="60dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Space Colony Manager"
        android:textSize="14sp"
        android:textColor="#C084B8"
        android:layout_marginTop="8dp"/>

    <!-- logo placeholder -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="48dp"
        android:background="#2D1050">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="[ LOGO ]"
            android:textColor="#6A3080"
            android:textSize="18sp"/>

    </FrameLayout>

    <!-- pushes play button to bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/playBtn"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="PLAY"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A0A2E"
        android:backgroundTint="#FFB3DE"
        android:layout_marginBottom="48dp"/>

</LinearLayout>