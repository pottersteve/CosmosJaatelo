<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A0A2E"
    android:padding="16dp">

    <Button android:id="@+id/backBtnStats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="← Back" android:textColor="#FFB3DE" android:backgroundTint="#2D1050" android:textSize="11sp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="COLONY OVERVIEW" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="16dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginTop="8dp">
        <TextView android:id="@+id/totalMissionsText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Missions: 0" android:textColor="#C084B8" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/totalWinsText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Wins: 0" android:textColor="#00FF00" android:gravity="center" android:textStyle="bold"/>
        <TextView android:id="@+id/totalLossesText" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Losses: 0" android:textColor="#FF0000" android:gravity="center" android:textStyle="bold"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#3D1A60" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CREW DOSSIERS" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:gravity="center"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="8dp">
        <LinearLayout android:id="@+id/crewStatsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        </LinearLayout>
    </ScrollView>

</LinearLayout>